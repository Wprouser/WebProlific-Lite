# Copy this file to .env and adjust as needed for your environment.
# For e2e tests (npm run test:e2e), also copy .env.test.example to
# .env.test — a separate database so test cleanup never touches this one.

# Local dev SQL Server (matches docker-compose.yml defaults)
MSSQL_SA_PASSWORD="DevP@ssw0rd123!"
DATABASE_URL="sqlserver://localhost:1433;database=webprolific_dev;user=sa;password=DevP@ssw0rd123!;trustServerCertificate=true"

PORT=3000

# FR-13: Authentication & 2FA
# JWT_ACCESS_SECRET: any long random string in dev; a real secret manager value in prod.
JWT_ACCESS_SECRET="dev-only-change-me-1f8a9c2e4b6d7f01"
JWT_ACCESS_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_IN_DAYS=30
PENDING_2FA_TOKEN_TTL_MIN=10
TRUSTED_DEVICE_TTL_DAYS=30
# TOTP_ENCRYPTION_KEY: 32 random bytes, base64-encoded (e.g. `openssl rand -base64 32`).
TOTP_ENCRYPTION_KEY="4h2sM9pQeYVvXk1n8Zt6rC0dJb3fL5wA7gU2iN9oR4E="
