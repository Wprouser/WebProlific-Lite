// FR-00: Multi-Tenant Organizational Hierarchy (Chain -> Property -> Outlet)
// Models transcribed as specified in docs/Technical_Spec_Core_Inventory_Module.md.
// SQL Server via Prisma — no native scalar arrays / Json type; see the spec's
// "SQL Server schema compatibility notes" for why that constrains later FRs.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

// NOTE: Prisma's SQL Server connector does not support the `enum` schema
// construct at all (unlike its Postgres/MySQL connectors) — declaring one
// here fails schema validation outright. So PropertyType/OutletType/ScopeType/
// Role are modeled as `String` columns instead, with the allowed value sets
// enforced as TS union types + class-validator `@IsIn(...)` at the application
// layer (src/tenancy/constants/enums.ts) — the same "enforced above the DB,
// not by it" outcome the spec's compatibility notes describe, just moved one
// layer up since the connector won't accept the enum syntax itself.

model Chain {
  id               String     @id @default(uuid())
  name             String
  baseCurrency     String     @default("SAR")
  subscriptionPlan String     @default("STANDARD")
  isActive         Boolean    @default(true)
  createdAt        DateTime   @default(now())
  properties       Property[]
}

model Property {
  id       String   @id @default(uuid())
  chainId  String
  chain    Chain    @relation(fields: [chainId], references: [id])
  name     String
  type     String // PropertyType: HOTEL | STANDALONE_RESTAURANT | RESTAURANT_GROUP_SITE
  address  String?
  timezone String   @default("Asia/Riyadh")
  isActive Boolean  @default(true)
  outlets  Outlet[]

  @@index([chainId])
}

model Outlet {
  id                  String   @id @default(uuid())
  propertyId          String
  property            Property @relation(fields: [propertyId], references: [id])
  chainId             String // denormalized from property.chainId for fast scoped queries — see spec note
  name                String
  type                String // OutletType: RESTAURANT | BAR | KITCHEN | STORE | ROOM_SERVICE
  baseCurrency        String   @default("SAR")
  poApprovalThreshold Decimal? @db.Decimal(12, 2)
  isActive            Boolean  @default(true)
  items               Item[]

  @@index([propertyId])
  @@index([chainId])
}

model UserAccess {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  scopeType String // ScopeType: CHAIN | PROPERTY | OUTLET
  scopeId   String // a chainId, propertyId, or outletId, depending on scopeType
  role      String // Role: CHAIN_OWNER | PROPERTY_MANAGER | OUTLET_MANAGER | STORE_STAFF | CHEF
  createdAt DateTime @default(now())

  @@unique([userId, scopeType, scopeId])
  @@index([userId])
}

// FR-13: Authentication & Login (with Two-Factor Authentication)
// TwoFactorMethod (TOTP | SMS | EMAIL) is a String column, not a Prisma `enum`
// block — see the header note above; enforced via src/auth/constants/enums.ts.

model User {
  id                  String               @id @default(uuid())
  email               String               @unique
  phone               String?
  // Nullable: FR-14's invite flow creates a User row with isActive=false and
  // no password yet — it's only set once the invite is accepted.
  passwordHash        String?
  preferredLanguage   String               @default("en") // 'en' | 'ar'
  preferredCurrency   String               @default("SAR")
  isActive            Boolean              @default(true)
  lastLoginAt         DateTime?
  createdAt           DateTime             @default(now())
  // role is no longer a flat field — see FR-00 UserAccess for per-scope role assignment
  twoFactor           TwoFactorAuth?
  userAccesses        UserAccess[]
  refreshTokens       RefreshToken[]
  passwordResets      PasswordResetToken[]
  trustedDevices      TrustedDevice[]
  twoFactorChallenges TwoFactorChallenge[]
  inviteTokens        InviteToken[]
  auditLogs           AuditLog[]
  activityLogs        ActivityLog[]
  transactionLogs     TransactionLog[]
}

model TwoFactorAuth {
  id               String                @id @default(uuid())
  userId           String                @unique
  user             User                  @relation(fields: [userId], references: [id])
  isEnabled        Boolean               @default(false)
  method           String                @default("TOTP") // TwoFactorMethod: TOTP | SMS | EMAIL
  totpSecret       String? // encrypted at rest; only set if method = TOTP
  enforcedByPolicy Boolean               @default(false) // true if CHAIN_OWNER has mandated 2FA for all users in the tenant
  enrolledAt       DateTime?
  backupCodes      TwoFactorBackupCode[]
}

model TwoFactorBackupCode {
  id              String        @id @default(uuid())
  twoFactorAuthId String
  twoFactorAuth   TwoFactorAuth @relation(fields: [twoFactorAuthId], references: [id])
  codeHash        String // single-use recovery code, hashed
  usedAt          DateTime?
  createdAt       DateTime      @default(now())

  @@index([twoFactorAuthId])
}

model TwoFactorChallenge {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  code         String? // hashed OTP, for SMS/EMAIL method; null for TOTP (verified against totpSecret directly)
  method       String // TwoFactorMethod: TOTP | SMS | EMAIL
  expiresAt    DateTime // short-lived, e.g. 5-10 minutes
  attemptCount Int       @default(0)
  consumedAt   DateTime?

  @@index([userId])
}

model TrustedDevice {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  deviceToken String   @unique // sha256 hash of the raw token stored client-side; presented to skip 2FA on "remember this device"
  deviceLabel String? // e.g. "Manager's iPhone", "Front Desk PC"
  expiresAt   DateTime // e.g. 30 days
  createdAt   DateTime @default(now())

  @@index([userId])
}

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  tokenHash  String
  expiresAt  DateTime
  revokedAt  DateTime?
  deviceInfo String?

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?

  @@index([userId])
}

// FR-11: Role-Based Access Control
// "Every mutating endpoint must write an AuditLog entry" — distinct from
// FR-18's later, unified ActivityLog/TransactionLog (which layers on top of
// this, not replaces it — see the Technical Spec's FR-18 intro).
model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String
  entityType String
  entityId   String
  outletId   String? // not every audited action is outlet-scoped (e.g. a chain-level change)
  // Structured before/after snapshots — String (NVARCHAR(MAX)) per the SQL
  // Server compatibility note (no native Json column type); JSON.stringify/
  // parse happens at the repository boundary.
  before     String?
  after      String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
}

// FR-14: User Management
// Same shape as PasswordResetToken — reused deliberately (see implementation
// plan) over a stateless signed JWT, since a resend/accept needs to be able
// to invalidate the previous token, which a stateless JWT can't do.
model InviteToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// FR-18: Activity & Transaction Log (System-Wide)
// ActivityCategory is a String column, not a Prisma `enum` block — see the
// header note above; enforced via src/activity-log/constants/enums.ts.
// Layers on top of FR-11's AuditLog (see that model's note), not a
// replacement for it — every write path that already produces an AuditLog
// row also produces an ActivityLog row (always) and, if it created,
// updated, or deleted a master-data or transactional entity, one or more
// TransactionLog rows (one per changed field on updates) — via the
// domain-event bus in src/activity-log/services/activity-bus.service.ts.
model ActivityLog {
  id          String   @id @default(uuid())
  chainId     String?
  propertyId  String?
  outletId    String?
  userId      String? // null for system-generated events (e.g. scheduled AI jobs)
  user        User?    @relation(fields: [userId], references: [id])
  category    String // ActivityCategory
  action      String // e.g. "ITEM_CREATED", "PO_APPROVED", "LOGIN_SUCCESS", "2FA_ENABLED"
  entityType  String?
  entityId    String?
  // Human-readable, localized at render time via a message key, not stored
  // pre-translated — see FR-15's rendering approach in the spec.
  description String
  // JSON-serialized string (NVARCHAR(MAX)) — SQL Server has no native Json
  // type via Prisma, so serialize/deserialize at the repository layer, same
  // pattern as AuditLog.before/after.
  metadata    String?
  ipAddress   String?
  deviceInfo  String?
  createdAt   DateTime @default(now())

  @@index([outletId, createdAt])
  @@index([chainId, createdAt])
  @@index([userId, createdAt])
  @@index([category, createdAt])
}

// FR-18 (revised): a field-level change record for any create/update/delete
// on master data (Item, Category, Supplier, Recipe, TaxRate, Currency,
// User, Outlet/Property/Chain settings) or transactional data
// (StockTransaction, PurchaseOrder, GRN, Transfer, Sale) — one row per
// changed field on updates, regardless of whether the change carries a
// monetary value. `valueAmount` is optional enrichment only, not the
// defining criterion for whether a row exists.
model TransactionLog {
  id             String   @id @default(uuid())
  // Deliberately nullable, deviating from the original "outletId String"
  // shape — chain/property-level master-data changes (Chain, Property
  // settings) have no single outlet to attach to. At least one of
  // chainId/propertyId/outletId is always set; which one(s) depends on the
  // entity's own place in the hierarchy. See AuditLogService's
  // buildEntityChange for the resolution logic.
  outletId       String?
  chainId        String?
  propertyId     String?
  entityCategory String // EntityCategory: 'MASTER_DATA' | 'TRANSACTIONAL'
  entityType     String // e.g. 'Item', 'Supplier', 'PurchaseOrder', 'StockTransaction'
  entityId       String // FK to the actual record that changed
  operation      String // Operation: 'CREATE' | 'UPDATE' | 'DELETE'
  fieldName      String? // the specific field that changed (null for CREATE/DELETE)
  oldValue       String? // string-serialized previous value (null for CREATE)
  newValue       String? // string-serialized new value (null for DELETE)
  valueAmount    Decimal? @db.Decimal(12, 2)
  currencyCode   String?
  performedById  String?
  performedBy    User?    @relation(fields: [performedById], references: [id])
  // Message key, not a frozen sentence — rendered at read time via FR-15
  // i18n using this row's own entityType/fieldName/oldValue/newValue as
  // interpolation data, same "localized at render time" pattern as
  // ActivityLog.description.
  summary        String
  createdAt      DateTime @default(now())

  @@index([outletId, createdAt])
  @@index([propertyId, createdAt])
  @@index([chainId, createdAt])
  @@index([entityType, entityId])
  @@index([entityCategory, createdAt])
}

// FR-01: Item Master Management
// Unit is a String column, not a Prisma `enum` block — see the header note
// above; enforced via src/items/constants/enums.ts.
model Item {
  id                String   @id @default(uuid())
  outletId          String
  outlet            Outlet   @relation(fields: [outletId], references: [id])
  name              String
  categoryId        String
  category          Category @relation(fields: [categoryId], references: [id])
  sku               String   @unique
  // Deliberately not @unique, unlike sku — SQL Server's default unique
  // index treats every NULL as equal (unlike Postgres, where NULL != NULL
  // for uniqueness purposes), so a plain @unique here would reject a
  // second item with no barcode at all. Uniqueness is still enforced when
  // a barcode IS provided, via ItemsService's findByBarcode check.
  barcode           String?
  unit              String // Unit: KG | LITRE | PIECE | BOX | GRAM | ML
  minStock          Decimal  @db.Decimal(10, 3)
  maxStock          Decimal  @db.Decimal(10, 3)
  // Denormalized, updated only by FR-02's Stock Transaction service — never
  // written directly by this module's own create/update endpoints.
  currentStock      Decimal  @default(0) @db.Decimal(10, 3)
  shelfLifeDays     Int?
  costPrice         Decimal  @db.Decimal(12, 2)
  // No Supplier relation — FR-03 (Suppliers) isn't built yet, so this is a
  // loose reference for now, same pattern as AuditLog's polymorphic ids.
  defaultSupplierId String?
  storageLocation   String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([outletId, isActive])
  @@index([categoryId])
  @@index([barcode])
}

model Category {
  id       String @id @default(uuid())
  name     String
  outletId String
  items    Item[]

  @@unique([name, outletId])
}
